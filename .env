########################################################################################################################
## Creating dev environement file
########################################################################################################################

RUSTY_ROOT=$(pwd)
export PATH=$PATH:$(pwd)/target/debug
export HISTFILE=$(pwd)/.bash_history

export PS1=$'\[\e[1;34m\]Rust\[\e[m\] [\W] \$ '

export RUST_LOG=warn

function files () {
	cd $RUSTY_ROOT
	echo Cargo.toml
	find rust | grep -e \\\.rs$ -e \\\.toml
	find db | grep \\\.sql
	echo db/refresh-sample-db
	find res/html | grep \\\.html$
	find res/js | grep \\\.js$
	find res/json | grep \\\.json$
	find res/css | grep \\\.css$
}

LOCAL_ENV_FILE=${LOCAL_ENV_FILE:-~/.config/rusty/env}

mkdir -p $(dirname $LOCAL_ENV_FILE)
touch $LOCAL_ENV_FILE

. $LOCAL_ENV_FILE

