########################################################################################################################
## Creating dev environement file
########################################################################################################################

RUSTY_ROOT=$(pwd)
export PATH=$PATH:$(pwd)/target/debug
export HISTFILE=$(pwd)/.bash_history

export PS1=$'\[\e[1;34m\]Rust\[\e[m\] [\W] \$ '

export RUST_LOG=warn

function files () {
	cd $RUSTY_ROOT
	echo Cargo.toml
	find rust | grep -e \\\.rs$ -e \\\.toml
	find db | grep \\\.sql
	find db -executable -type f
	find res/html | grep \\\.html$
	find res/js | grep \\\.js$
	find res/json | grep \\\.json$
	find res/css | grep \\\.css$
}

W1_PORT=7031
W2_PORT=7032

function log () {
	if [ -n "$CP_LOG" ]; then
		echo $*
	fi
}

function stop-svc () {
	PID_FILE=$1

	if [ -f "$PID_FILE" ]; then
		PID=$(cat $PID_FILE)
		if [ -n "$PID" ]; then
			NAME=$(ps -q $PID -o comm=)
			if [ -n "$NAME" ]; then
				log "Killing $NAME ($PID)"
				kill $PID
			fi	
		fi

		rm $PID_FILE
	fi
}

function stop-all () {
	stop-svc ~/.cp.pid
	stop-svc ~/.ui.pid
	stop-svc ~/.w1.pid
	stop-svc ~/.w2.pid
}

function start-all () {
	stop-all

	mkdir -p ./log
	
	log "Starting CP Service"
	cp-svr > log/cp.log &
	echo $! > ~/.cp.pid
	sleep 1

	log "Starting UI Service"
	ui-svr > log/ui.log  &
	echo $! > ~/.ui.pid

	log "Starting W1 Service"
	w-svr --port $W1_PORT  > log/w1.log &
	echo $! > ~/.w1.pid

	log "Starting W2 Service"
	w-svr --port $W2_PORT  > log/w2.log &
	echo $! > ~/.w2.pid
}


########################################################################################################################
# Create in needed, then load local config file
########################################################################################################################

function write_new_local_env_file () {
	cat > $1 << EOF
########################################################################################################################
## Configuration file for Rust environment
########################################################################################################################

# export RUST_LOG=
# export MYSQL_PASSWORD=
# export RUST_BACKTRACE=1
EOF
}

LOCAL_RUST_ENV_CONFIG=${LOCAL_RUST_ENV_CONFIG:-~/.config/rusty/env}

mkdir -p $(dirname $LOCAL_RUST_ENV_CONFIG)

if [ ! -f $LOCAL_RUST_ENV_CONFIG ]; then
	write_new_local_env_file $LOCAL_RUST_ENV_CONFIG
fi

. $LOCAL_RUST_ENV_CONFIG

